{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],
    "noEmit": true,
    "paths": {
      "@shared/*": ["src/shared/*"]
    }
  },
  "include": ["electron/**/*", "src/server/**/*", "src/shared/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
