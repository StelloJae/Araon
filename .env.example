# Araon optional runtime environment
#
# KIS appKey/appSecret are entered through the local setup UI and are stored in
# data/credentials.enc, which is ignored by git. Do not put brokerage secrets in
# this file.

# Recommended: set a stable, private encryption seed for data/credentials.enc.
# Use a long random value and keep it outside git.
KIS_CRED_KEY=replace-with-a-long-random-local-secret

# Optional logging level: trace, debug, info, warn, error, fatal.
LOG_LEVEL=info

# Optional news/disclosure enrichment.
# Naver Search API credentials are issued from Naver Developers after enabling
# the Search API. DART_API_KEY is issued from OpenDART.
# Leave these blank to use only the no-key Naver Finance link feed and external
# disclosure search links.
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=
DART_API_KEY=

# Optional production mode for local deployments.
NODE_ENV=production
