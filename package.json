{
  "name": "araon",
  "version": "1.0.0",
  "private": false,
  "description": "A localhost-first Korean stock watchlist dashboard with KIS OpenAPI realtime support.",
  "license": "Apache-2.0",
  "author": "Araon contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/StelloJae/Araon.git"
  },
  "bugs": {
    "url": "https://github.com/StelloJae/Araon/issues"
  },
  "homepage": "https://github.com/StelloJae/Araon#readme",
  "keywords": [
    "korean-stocks",
    "kis-openapi",
    "watchlist",
    "realtime",
    "nxt"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "tsc -p tsconfig.server.json && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "vite build",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.client.json --noEmit",
    "typecheck:server": "tsc -p tsconfig.server.json --noEmit",
    "typecheck:client": "tsc -p tsconfig.client.json --noEmit",
    "test": "vitest run --fileParallelism=false"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "better-sqlite3": "^11.0.0",
    "fastify": "^5.0.0",
    "iconv-lite": "^0.7.2",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  }
}
